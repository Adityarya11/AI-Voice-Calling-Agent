# Copy this file to .env and set your own credentials.

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+10000000000
MY_PHONE_NUMBER=+10000000000

# VAPI (primary telephony orchestration)
VAPI_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# OpenAI
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ElevenLabs
ELEVEN_LABS_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ELEVEN_LABS_VOICE_ID=ThT5KcBeYPX3keUQqHPh

# Public URL (ngrok / cloud tunnel / deployed domain)
NGROK_URL=https://your-public-url.example.com
BASE_URL=http://localhost:8000

# Data + memory
DATABASE_URL=sqlite:///./riverwood.db
REDIS_URL=redis://localhost:6379/0
TTS_OUTPUT_DIR=./data/audio

# Runtime mode
SIMULATE_TELEPHONY=true
